# Synthetic negatives: agent-stack lookalikes that must never fire.
# Wrong length, wrong charset, or non-secret sibling prefixes.
TAVILY_STUB=tvly-short
TAVILY_UNDERSCORE=tvly_AbC123Def456Ghi789Jkl012Mno
FIRECRAWL_SHORT=fc-0123456789abcdef0123456789abcde
FIRECRAWL_UPPER=fc-0123456789ABCDEF0123456789ABCDEF
FIRECRAWL_PROSE=fc-barcelona fixtures fetched
NVIDIA_SHORT=nvapi-Ab0cdefghij
CEREBRAS_SHORT=csk-x1y2z3
CEREBRAS_DOTTED=csk-not.a.real.key.shape
LANGFUSE_PUBLIC=pk-lf-01234567-89ab-cdef-0123-456789abcdef
LANGFUSE_MALFORMED=sk-lf-0123-nope
FIGMA_SHORT=figd_Ab0cd
# fc- inside identifiers and hostnames stays out on word boundaries:
HOST=grid-fc-0123456789abcdef0123456789abcdef.internal
