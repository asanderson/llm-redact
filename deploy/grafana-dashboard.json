{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the llm-redact proxy",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "llm-redact proxy",
  "uid": "llm-redact",
  "tags": ["llm-redact", "privacy", "proxy"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Data source"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Traffic",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Request rate by provider",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (provider) (rate(llm_redact_requests_total[5m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error responses (4xx/5xx) by provider",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (provider) (rate(llm_redact_requests_total{status=~\"4..|5..\"}[5m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "In-proxy duration (p50 / p95)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_redact_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_redact_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Uptime",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "max(llm_redact_uptime_seconds)", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Vault sessions / entries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "max(llm_redact_vault_sessions)", "legendFormat": "sessions", "refId": "A" },
        { "expr": "max(llm_redact_vault_entries)", "legendFormat": "entries", "refId": "B" }
      ]
    },
    {
      "type": "row",
      "title": "Detection",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "type": "timeseries",
      "title": "Detections (redacted) by type",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "cps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (type) (rate(llm_redact_detections_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Warnings by type (VALUE FORWARDED UPSTREAM)",
      "description": "Warn mode counts the detection but sends the real value upstream. A non-zero line means values are leaving the box by design — confirm it is intended.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "cps", "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (type) (rate(llm_redact_warnings_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Blocked requests by type",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "cps", "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (type) (rate(llm_redact_blocked_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rehydrations by type",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "cps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (type) (rate(llm_redact_rehydrations_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Compaction forks (1h)",
      "description": "Per-conversation history compaction forks a fresh vault session (documented never-wrong-value tradeoff, docs/compaction-relink.md).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "increase(llm_redact_compaction_forks_total[1h])", "refId": "A" }
      ]
    }
  ]
}
